# Copy to .env and fill in. Only DATABASE_URL and AUTH_SECRET are required —
# everything else has a local fallback (console email, local-disk uploads).
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/assetflow"
AUTH_SECRET="generate-with: openssl rand -base64 32"
APP_URL="http://localhost:3000"
# RESEND_API_KEY=          # optional: real email delivery
# BLOB_READ_WRITE_TOKEN=   # optional: Vercel Blob file storage in prod
# CRON_SECRET=             # protects /api/jobs/* endpoints in prod
